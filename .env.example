# 1. Create a bot via @BotFather on Telegram → copy the token here
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Get your chat ID:
#    - Send any message to your bot
#    - Open https://api.telegram.org/bot<TOKEN>/getUpdates
#    - Copy "id" from result.message.chat
TELEGRAM_CHAT_ID=123456789

# Secret header for GET /api/leads — pick any random string
ADMIN_TOKEN=change-me

PORT=3000
